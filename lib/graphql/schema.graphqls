type Mutation {
  addBrowserPushSubscription(input: AddBrowserPushSubscriptionInput!): AddBrowserPushSubscription
  addRecommendationFeedback(input: AddRecommendationFeedbackInput!): AddRecommendationFeedback
  beginUseBitsInExtension(
    input: Mutation_BeginUseBitsInExtension_Input_Input
  ): BeginUseBitsInExtension
  blockUser(input: BlockUserInput!): BlockUser
  completePasskeyRegistration(input: CompletePasskeyRegistrationInput!): CompletePasskeyRegistration
  confirmLiveShoppingOrders(
    input: ConfirmLiveShoppingOrdersInput!
  ): [ConfirmLiveShoppingOrdersPayload]
  connectAdIdentity(input: ConnectAdIdentityInput!): ConnectAdIdentity
  createBitsChallengeConditionForExtension(
    input: Mutation_CreateBitsChallengeConditionForExtension_Input_Input
  ): CreateBitsChallengeConditionForExtension
  createBitsChallengeConditionParticipantForExtension(
    input: Mutation_CreateBitsChallengeConditionParticipantForExtension_Input_Input
  ): CreateBitsChallengeConditionParticipantForExtension
  createCreatorMessage(input: CreateCreatorMessageInput!): CreateCreatorMessage
  deleteCreatorMessage(input: DeleteCreatorMessageInput!): DeleteCreatorMessage
  deleteCreatorMessageForViewer(
    input: DeleteCreatorMessageForViewerInput!
  ): DeleteCreatorMessageForViewer
  deleteNotification(input: DeleteNotificationInput!): DeleteNotification
  endUseBitsInExtension(input: Mutation_EndUseBitsInExtension_Input_Input): EndUseBitsInExtension
  exchangeRelayCode(input: Mutation_ExchangeRelayCode_Input_Input): ExchangeRelayCode
  extensionLinkUser(input: Mutation_ExtensionLinkUser_Input_Input): ExtensionLinkUser
  followUser(input: JSON): FollowUser
  initPasskeyRegistration: InitPasskeyRegistration
  linkPrimeAccount(input: LinkPrimeAccountInput!): LinkPrimeAccount
  markAllCreatorNotificationsAsRead(
    input: MarkAllCreatorNotificationsAsReadInput!
  ): MarkAllCreatorNotificationsAsRead
  markAllViewerNotificationsAsRead(
    input: MarkAllViewerNotificationsAsReadInput
  ): MarkAllViewerNotificationsAsRead
  markCreatorMessageRead(input: MarkCreatorMessageReadInput!): MarkCreatorMessageRead
  optInSpendableBalance: OptInSpendableBalance
  placeOrder(input: PlaceOrderInput!): PlaceOrder
  previewLiveShoppingOrders(
    input: PreviewLiveShoppingOrdersInput!
  ): [PreviewLiveShoppingOrdersPayload]
  purchaseOffer(input: PurchaseOfferInput!): PurchaseOffer
  readNotifications(input: ReadNotificationsInput!): [ReadNotification]
  recordAdEvent(input: RecordAdEventInput!): RecordAdEvent
  refreshExtensionHelixToken(
    input: Mutation_RefreshExtensionHelixToken_Input_Input
  ): RefreshExtensionHelixToken
  refreshExtensionToken(input: Mutation_RefreshExtensionToken_Input_Input): RefreshExtensionToken
  regenerateVerificationCode(input: RegenerateVerificationCodeInput!): RegenerateVerificationCode
  removeReactionByContentKey(input: RemoveReactionByContentKeyInput!): RemoveReactionByContentKey
  removeUserFromNotificationCampaign(
    input: RemoveUserFromNotificationCampaignInput!
  ): RemoveUserFromNotificationCampaign
  reportFeedInteractions(input: ReportFeedInteractionsInput!): [ReportFeedInteraction]
  sendChatMessage(input: SendChatMessageInput!): SendChatMessage
  sendExtensionMessage(input: Mutation_SendExtensionMessage_Input_Input): SendExtensionMessage
  sendSpadeEvents(input: SendSpadeEventsInput!): [SendSpadeEvent]
  setCelebrationsEnabled(input: SetCelebrationsEnabledInput!): SetCelebrationsEnabled
  setChatHappeningNowSettings(input: SetChatHappeningNowSettingsInput!): SetChatHappeningNowSetting
  setDiscoveryPreference(input: SetDiscoveryPreferenceInput!): SetDiscoveryPreference
  setEmoteAnimationsEnabled(input: SetEmoteAnimationsEnabledInput!): SetEmoteAnimationsEnabled
  setExtensionConfiguration(
    input: Mutation_SetExtensionConfiguration_Input_Input
  ): SetExtensionConfiguration
  setLiveNotificationsEnrollment(
    input: SetLiveNotificationsEnrollmentInput!
  ): SetLiveNotificationsEnrollment
  setNotificationSetting(input: SetNotificationSettingInput!): SetNotificationSetting
  setPreferredLanguageTag(input: SetPreferredLanguageTagInput!): SetPreferredLanguageTag
  setSessionStatus(input: SetSessionStatusInput!): [SetSessionStatu]
  spendSubscriptionCredit(input: SpendSubscriptionCreditInput!): SpendSubscriptionCredit
  undoRecommendationFeedback(input: UndoRecommendationFeedbackInput!): UndoRecommendationFeedback
  unfollowUser(input: UnfollowUserInput!): UnfollowUser
  unlinkAmazonConnection(input: UnlinkAmazonConnectionInput!): UnlinkAmazonConnection
  unlockChosenModifiedSubscriberEmote(
    input: UnlockChosenModifiedSubscriberEmoteInput!
  ): UnlockChosenModifiedSubscriberEmote
  unlockChosenSubscriberEmote(input: UnlockChosenSubscriberEmoteInput!): UnlockChosenSubscriberEmote
  unlockRandomSubscriberEmote(input: UnlockRandomSubscriberEmoteInput!): UnlockRandomSubscriberEmote
  updateActivityFeedAlertStatus(
    input: UpdateActivityFeedAlertStatusInput!
  ): [UpdateActivityFeedAlertStatu]
  updateAllWhisperThreads(input: UpdateAllWhisperThreadsInput!): [UpdateAllWhisperThread]
  updateChannelClipsSetting(input: UpdateChannelClipsSettingInput!): UpdateChannelClipsSetting
  updateClipViewCount(input: UpdateClipViewCountInput!): UpdateClipViewCount
  updateConsent(input: UpdateConsentInput!): UpdateConsent
  updatePhoneNumber(input: UpdatePhoneNumberInput!): UpdatePhoneNumber
  updatePhoneNumberConfirmation(
    input: UpdatePhoneNumberConfirmationInput!
  ): UpdatePhoneNumberConfirmation
  updateReactionByContentKey(input: UpdateReactionByContentKeyInput!): UpdateReactionByContentKey
