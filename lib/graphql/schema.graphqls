type Query {
  activeHypeTrainStatuses(channelIDs: [ID!]!): [ActiveHypeTrainStatus]
  adContext(context: AdRequestContext!): AdContext
  aggregateReactionsBreakdownByContentKeys(
    contentKeys: [ReactionsContentKey!]!
  ): [AggregateReactionsBreakdownByContentKey]
  alertsFeatureLaunchFlags(channelID: ID!): [AlertsFeatureLaunchFlags]
  allActiveHypeTrainStatuses(channelIDs: [ID!]!): [AllActiveHypeTrainStatus]
  availableReactionsByContentType(
    channelID: ID
    contentType: ReactionsContentType!
  ): AvailableReactionsByContentType
  batchGetWatchStreaks: [BatchGetWatchStreak]
  bitsOffers: [BitsOffer]
  canCreateClip(broadcasterID: ID, vodID: ID): CanCreateClip
  channel(id: ID, name: String): Channel
  cheerConfig: CheerConfig
  clip(slug: ID!): Clip
  collection(id: ID!): Collection
  consent(consentSessionID: ID!): Consent
  creatorMessageFeed(after: Cursor, first: Int): CreatorMessageFeed
  creatorMessagesAvailable: CreatorMessagesAvailable
  creatorMessagingCohorts: [CreatorMessagingCohort]
  creatorSentMessages(after: Cursor, first: Int): [CreatorSentMessage]
  currentReactionsByContentKeys(
    contentKeys: [ReactionsContentKey!]!
  ): [CurrentReactionsByContentKey]
  currentUser: User
  discoveryPreference: DiscoveryPreference
  emote(id: ID!): Emote
  extension(id: ID!, version: String): Extension
  featuredStreams(acceptedMature: Boolean, first: Int, language: String): [FeaturedStream]
  feedItems(input: Query_FeedItems_Input_Input): [FeedItem]
  game(id: ID, name: String, slug: String): Game
  games(after: Cursor, first: Int): FlowGameConnection
  guestStarChannelCollaboration(
    options: GuestStarChannelCollaborationOptions
  ): GuestStarChannelCollaboration
  guestStarCollaborationStatuses(
    options: GuestStarChannelCollaborationOptions
  ): [GuestStarCollaborationStatus]
  guestStarSessionsForViewers(options: GuestStarSessionsOptions): [GuestStarSessionForViewers]
  hasSpendableBalanceVideoBannerPromoEligibility(
    channelID: ID!
  ): HasSpendableBalanceVideoBannerPromoEligibility
  identityVerificationRequirement: IdentityVerificationRequirement
  isUsernameAvailable(username: String!): Boolean
  liveShoppingProductDetails(
    input: Query_LiveShoppingProductDetails_Input_Input
  ): [LiveShoppingProductDetail]
  liveShoppingProductSummaries(
    input: Query_LiveShoppingProductSummaries_Input_Input
  ): [LiveShoppingProductSummary]
  mobileExtensionInstallation(
    channelID: ID!
    extensionID: ID!
    version: String
  ): MobileExtensionInstallation
  payoutThresholdEarningsResolver(id: ID!): PayoutThresholdEarningsResolver
  plusStatus(channelID: ID!): [PlusStatu]
  primeOffersWithEligibility(countryCode: String, dateOverride: Time): PrimeOffersWithEligibility
  primeOffersWithoutEligibility(
    countryCode: String
    dateOverride: Time
  ): PrimeOffersWithoutEligibility
  requestInfo: RequestInfo
  searchCategories(after: Cursor, first: Int, query: String!): FlowGameConnection
  searchSuggestions(
    queryFragment: String!
    requestID: ID
    withOfflineChannelContent: Boolean
  ): SearchSuggestion
  searchUsers(userQuery: String!): [SearchUser]
  sharedChatSession(channelID: ID!): SharedChatSession
  shelves(
    after: Cursor
    context: RecommendationsContext
    first: Int
    itemsPerRow: Int
    langWeightedCCU: Boolean
    platform: String!
    requestID: String!
    verbose: Boolean
  ): [Shelve]
  sideNav(input: SideNavInput!): SideNav
  spendableBalance: SpendableBalance
  storyPreviewsWithOrder(input: StoryPreviewsWithOrderInput!): StoryPreviewsWithOrder
  streamPlaybackAccessToken(
    channelName: String!
    params: Query_StreamPlaybackAccessToken_Params_Input
  ): StreamPlaybackAccessToken
  subscriptionProduct(productName: String!): SubscriptionProduct
  user(id: ID, login: String, lookupType: JSON): User
  userByAttribute(input: UserByAttribute!): User
  userNotificationCampaigns(input: UserNotificationCampaignInput!): [NotificationCampaign]
  userResultByLogin(login: String!): UserResultByLogin
  streams(after: Cursor, first: Int): FlowStreamConnection
  users(ids: [ID!], logins: [String!]): [User]
  verificationRequest(opaqueID: ID!): VerificationRequest
  video(id: ID, options: Query_Video_Options_Input): Video
  videoPlaybackAccessToken(
    id: ID!
    params: Query_VideoPlaybackAccessToken_Params_Input
  ): VideoPlaybackAccessToken
  whisperThread(id: ID!): WhisperThread
}

